<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GF インセルダム 売上ランキング</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --green: #0F6E56;
    --green-light: #E1F5EE;
    --blue: #185FA5;
    --red: #E24B4A;
    --amber: #BA7517;
    --teal: #1D9E75;
    --bg: #F5F4F0;
    --surface: #FFFFFF;
    --border: rgba(0,0,0,0.08);
    --text: #1a1a1a;
    --text-muted: #6B6B6B;
    --radius: 14px;
    --radius-sm: 8px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', 'Noto Sans JP', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

  .site-header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 20px; position: sticky; top: 0; z-index: 100; }
  .header-inner { max-width: 700px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 56px; }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-dot { width: 10px; height: 10px; background: var(--green); border-radius: 50%; }
  .logo-text { font-size: 16px; font-weight: 700; color: var(--text); }
  .logo-sub { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
  .last-updated { font-size: 11px; color: var(--text-muted); }

  .container { max-width: 700px; margin: 0 auto; padding: 20px 16px 80px; }

  /* 月セレクター */
  .month-bar { display: flex; gap: 6px; margin-bottom: 20px; flex-wrap: wrap; align-items: center; }
  .month-bar-label { font-size: 12px; color: var(--text-muted); margin-right: 4px; }
  .mtab { flex-shrink: 0; padding: 7px 18px; border-radius: 20px; border: 1px solid var(--border); background: var(--surface); cursor: pointer; font-size: 13px; color: var(--text-muted); transition: all .15s; font-family: inherit; font-weight: 500; }
  .mtab.active { background: var(--green); color: #fff; border-color: transparent; }
  .mtab:hover:not(.active) { border-color: var(--green); color: var(--green); }

  /* ランキング */
  .rank-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }

  .rank-row { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: all .18s; }
  .rank-row:hover { box-shadow: 0 4px 16px rgba(0,0,0,.08); transform: translateY(-1px); }
  .rank-row.selected { border-color: var(--green); border-width: 2px; }

  .rank-main { display: flex; align-items: center; gap: 12px; padding: 14px 16px 10px; }
  .rank-pos { font-size: 22px; min-width: 32px; text-align: center; }
  .rank-pos-num { font-size: 15px; font-weight: 700; color: var(--text-muted); min-width: 32px; text-align: center; }
  .rank-avatar { width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; flex-shrink: 0; }
  .rank-body { flex: 1; min-width: 0; }
  .rank-name { font-size: 15px; font-weight: 700; color: var(--text); }
  .rank-sales-total { font-size: 13px; color: var(--text-muted); margin-top: 3px; font-weight: 500; }
  .rank-right { text-align: right; flex-shrink: 0; }
  .rank-score { font-size: 22px; font-weight: 700; color: var(--green); line-height: 1; }
  .rank-score-lbl { font-size: 10px; color: var(--text-muted); margin-top: 1px; }

  /* バー */
  .rank-bar-area { padding: 0 16px 10px; }
  .rank-bar-bg { height: 4px; background: #eee; border-radius: 2px; overflow: hidden; }
  .rank-bar-fill { height: 100%; border-radius: 2px; transition: width .6s ease; }

  /* 詳細ボタン */
  .rank-cta { margin: 0 16px 14px; }
  .rank-cta-btn { display: block; width: 100%; padding: 10px; border-radius: var(--radius-sm); border: none; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all .15s; text-align: center; }
  .rank-cta-btn.open-btn { background: var(--green); color: #fff; }
  .rank-cta-btn.close-btn { background: #f0f0f0; color: var(--text-muted); }
  .rank-cta-btn:hover { opacity: .88; }

  /* 詳細パネル */
  .detail-panel { border-top: 1px solid var(--border); display: none; }
  .detail-panel.open { display: block; }

  .detail-hero { padding: 16px; background: linear-gradient(135deg, #f0faf6 0%, #fff 100%); border-bottom: 1px solid var(--border); }
  .hero-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .hero-left { display: flex; align-items: center; gap: 10px; }
  .hero-avatar { width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; }
  .hero-name { font-size: 17px; font-weight: 700; color: var(--text); }
  .hero-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; margin-top: 4px; }
  .hero-score-block { text-align: right; }
  .hero-score { font-size: 34px; font-weight: 700; color: var(--green); line-height: 1; }
  .hero-score-lbl { font-size: 11px; color: var(--text-muted); }
  .hero-vs { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

  .metrics-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  @media(max-width:500px){.metrics-grid{grid-template-columns:repeat(2,1fr)}}
  .metric-card { background: rgba(255,255,255,.85); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px; text-align: center; }
  .metric-val { font-size: 14px; font-weight: 700; color: var(--text); }
  .metric-lbl { font-size: 10px; color: var(--text-muted); margin-top: 2px; }

  /* タブ */
  .dtab-row { display: flex; border-bottom: 1px solid var(--border); overflow-x: auto; scrollbar-width: none; background: #fff; }
  .dtab-row::-webkit-scrollbar { display: none; }
  .dtab { flex-shrink: 0; padding: 12px 16px; font-size: 13px; color: var(--text-muted); cursor: pointer; border: none; background: transparent; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all .15s; font-family: inherit; font-weight: 500; }
  .dtab.active { color: var(--green); border-bottom-color: var(--green); font-weight: 700; }

  .panel-body { padding: 18px 16px; background: #fff; }
  .chart-wrap { position: relative; width: 100%; height: 280px; }

  /* アクション比較バー */
  .action-bars { display: flex; flex-direction: column; gap: 14px; }
  .ab-row { display: grid; grid-template-columns: 80px 1fr; gap: 10px; align-items: center; }
  .ab-label { font-size: 12px; color: var(--text-muted); text-align: right; font-weight: 500; }
  .ab-right { display: flex; flex-direction: column; gap: 4px; }
  .ab-track { position: relative; height: 22px; background: #f0f0f0; border-radius: 6px; overflow: hidden; }
  .ab-bar-top { position: absolute; top:0; left:0; height:100%; border-radius:6px; opacity:.2; }
  .ab-bar-you { position: absolute; top:0; left:0; height:100%; border-radius:6px; display:flex; align-items:center; padding-left:8px; transition: width .5s ease; }
  .ab-bar-label { font-size:10px; font-weight:700; color:#fff; white-space:nowrap; }
  .ab-meta { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:4px; }
  .ab-myval { font-size:12px; font-weight:600; color:var(--text); }
  .ab-topval { font-size:11px; color:var(--text-muted); }
  .ab-gap-pill { font-size:10px; font-weight:600; padding:2px 8px; border-radius:10px; }

  /* アドバイス */
  .advice-list { display:flex; flex-direction:column; gap:12px; }
  .advice-card { border-radius:var(--radius-sm); padding:14px 16px; border-left:4px solid; }
  .advice-card.weak { background:#fff5f5; border-left-color:var(--red); }
  .advice-card.mid  { background:#fffbf0; border-left-color:var(--amber); }
  .advice-card.good { background:#f0faf6; border-left-color:var(--teal); }
  .advice-tag { font-size:11px; font-weight:700; margin-bottom:5px; }
  .advice-card.weak .advice-tag { color:var(--red); }
  .advice-card.mid  .advice-tag { color:var(--amber); }
  .advice-card.good .advice-tag { color:var(--teal); }
  .advice-action-name { font-size:14px; font-weight:700; color:var(--text); margin-bottom:6px; }
  .advice-text { font-size:13px; color:var(--text); line-height:1.75; }
  .advice-numbers { font-size:11px; color:var(--text-muted); margin-top:6px; display:flex; gap:12px; flex-wrap:wrap; }

  .loading { text-align:center; padding:60px 20px; color:var(--text-muted); font-size:14px; }
  .loading-dot { display:inline-block; width:8px; height:8px; background:var(--green); border-radius:50%; margin:0 3px; animation:bounce .6s infinite alternate; }
  .loading-dot:nth-child(2){animation-delay:.2s}
  .loading-dot:nth-child(3){animation-delay:.4s}
  @keyframes bounce{to{transform:translateY(-6px)}}
  .error-box { background:#fff5f5; border:1px solid #fcc; border-radius:var(--radius-sm); padding:16px; font-size:13px; color:#c0392b; margin-bottom:16px; }
</style>
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <div class="logo">
      <div class="logo-dot"></div>
      <div>
        <div class="logo-text">GF インセルダム</div>
        <div class="logo-sub">売上ランキング</div>
      </div>
    </div>
    <div class="last-updated" id="lastUpdated"></div>
  </div>
</header>

<div class="container">
  <div id="loadingState" class="loading">
    <div style="margin-bottom:12px">データを読み込み中</div>
    <span class="loading-dot"></span><span class="loading-dot"></span><span class="loading-dot"></span>
  </div>
  <div id="errorState" class="error-box" style="display:none"></div>
  <div id="mainContent" style="display:none">
    <div class="month-bar" id="monthBar"></div>
    <div class="rank-list" id="rankList"></div>
  </div>
</div>

<script>
const SHEET_ID = '1oyEfnC2LoGCgn--ydpywNJ5Is7-eBL9_6Zszob7zdbA';
const GID = '462947909';

const AXES = [
  {k:'sales', label:'商品売上',      w:.25, max:1500000, fmt:v=>'¥'+v.toLocaleString()},
  {k:'mall',  label:'モール売上',    w:.20, max:600000,  fmt:v=>'¥'+v.toLocaleString()},
  {k:'story', label:'ストーリー',    w:.12, max:60,      fmt:v=>v+'件'},
  {k:'reel',  label:'リール',        w:.10, max:20,      fmt:v=>v+'件'},
  {k:'intro', label:'GF紹介',        w:.12, max:9,       fmt:v=>v+'件'},
  {k:'bEv',   label:'B説明会',       w:.08, max:5,       fmt:v=>v+'回'},
  {k:'cEv',   label:'C説明会',       w:.08, max:5,       fmt:v=>v+'回'},
  {k:'pm',    label:'PM獲得',        w:.05, max:11,      fmt:v=>v+'人'},
];

const PALETTES = ['#0F6E56','#185FA5','#D85A30','#7F77DD','#BA7517','#993556','#3B6D11','#085041'];

const TIPS = {
  sales:{ weak:'商品売上が最も伸ばしやすい項目です。既存顧客への3日以内フォローと、SNS投稿週2本以上を目指しましょう。', mid:'購入後のレビュー収集やリピート促進メッセージの送付で底上げを狙いましょう。', good:'商品売上は優秀です。モール売上とのバランスも意識しましょう。'},
  mall:{ weak:'RIMANモールの活用が少ないです。モール誘導投稿を週1本追加し、モール限定の魅力をSNSで発信しましょう。', mid:'ストーリーやリールでモールへの誘導を強化し、月間売上アップを狙いましょう。', good:'モール売上は好調です！この調子を維持しましょう。'},
  story:{ weak:'ストーリー投稿が少なすぎます。毎日1投稿（使用シーン・お客様の声）を習慣化しましょう。', mid:'ストーリーをあと週3〜4本増やすと大きく差が縮まります。朝晩のルーティン投稿を試しましょう。', good:'ストーリー投稿は高水準です。内容の多様化（Before/After・Q&A形式）も意識しましょう。'},
  reel:{ weak:'リール・フィード投稿が少ないです。週2〜3本を目標に、成分説明や使い方動画を投稿しましょう。', mid:'リール投稿を週1本増やすと大きく伸びます。「よくある質問」や「1ヶ月後の変化」系の動画は反応が取りやすいです。', good:'リール・フィード投稿は十分です！品質（字幕・サムネイル）の向上を検討しましょう。'},
  intro:{ weak:'GF公式LINEへの紹介数を伸ばすことがチーム全体の底上げにつながります。プロフィール欄に紹介リンクを常設しましょう。', mid:'紹介数をもう少し増やせると上位が見えてきます。フォロワーへの個別DM案内も効果的です。', good:'GF紹介は優秀です。紹介したお客様のフォローアップも丁寧に行いましょう。'},
  bEv:{ weak:'B向け説明会の開催が少ないです。月2回以上を目標に、オンライン説明会も活用しましょう。', mid:'B向け説明会をあと1回/月増やせると上位が見えてきます。既存メンバーとの共催も効果的です。', good:'B向け説明会は十分な回数です。参加後の個別フォローも丁寧に行いましょう。'},
  cEv:{ weak:'C向け体験会が少ないです。少人数のお茶会形式でも十分効果的です。積極的に場を作りましょう。', mid:'C向け体験会をもう1〜2回増やすとPM獲得率も上がります。紹介型体験会を試しましょう。', good:'C向け体験会は十分です。参加者のアフターフォローで成約率を上げましょう。'},
  pm:{ weak:'PM/M/SM獲得に大きな伸び代があります。体験会参加者への個別フォローを3日以内に行いましょう。', mid:'PM獲得をあと数人増やせると大きくスコアアップします。既存メンバーの成功体験を積極的に共有しましょう。', good:'PM/M/SM獲得は高水準です！チームの拡大を維持しましょう。'},
};

let allData = [];
let curMonth = '';
let chartInsts = {};

// 回答日から「先月」を計算
function toReportMonth(dateStr) {
  const m = dateStr.match(/(\d{4})-(\d{2})/);
  if (!m) return null;
  let y = parseInt(m[1]), mo = parseInt(m[2]);
  mo -= 1;
  if (mo === 0) { mo = 12; y -= 1; }
  return `${y}-${String(mo).padStart(2,'0')}`;
}

function parseCSV(text) {
  const lines = text.split(/\r?\n/).filter(l => l.trim());
  return lines.map(line => {
    const cols = []; let cur = '', inQ = false;
    for (let i = 0; i < line.length; i++) {
      if (line[i] === '"') { inQ = !inQ; }
      else if (line[i] === ',' && !inQ) { cols.push(cur); cur = ''; }
      else { cur += line[i]; }
    }
    cols.push(cur);
    return cols;
  });
}

function num(v) { const n = parseFloat((v||'').replace(/[^0-9.]/g,'')); return isNaN(n) ? 0 : n; }

async function fetchData() {
  const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${GID}`;
  const res = await fetch(url);
  if (!res.ok) throw new Error('スプレッドシートの取得に失敗しました');
  const text = await res.text();
  const rows = parseCSV(text);
  if (rows.length < 2) throw new Error('データが見つかりませんでした');

  allData = rows.slice(1).map(r => {
    const month = toReportMonth(r[2] || '');
    return {
      name:  r[6] || r[5] || '不明',
      month: month || '不明',
      sales: num(r[7]), mall: num(r[8]), story: num(r[9]),
      reel:  num(r[10]), intro: num(r[11]), bEv: num(r[12]),
      cEv:   num(r[13]), pm: num(r[14]),
    };
  }).filter(d => d.name && d.name !== '不明' && d.month !== '不明');

  document.getElementById('lastUpdated').textContent = '最終更新: ' + new Date().toLocaleDateString('ja-JP');
}

function calcScore(d) {
  return Math.round(AXES.reduce((s,a) => s + (Math.min(d[a.k],a.max)/a.max)*a.w*100, 0)*10)/10;
}

function getMonths() { return [...new Set(allData.map(d=>d.month))].sort().reverse(); }

function byMonth(m) {
  return allData.filter(d=>d.month===m).map(d=>({...d,score:calcScore(d)})).sort((a,b)=>b.score-a.score);
}

function fmtMonth(m) {
  const [y,mo] = m.split('-');
  return `${y}年${parseInt(mo)}月`;
}

// 先月のデフォルト
function getLastMonth() {
  const now = new Date();
  let y = now.getFullYear(), mo = now.getMonth(); // getMonth()は0始まり→これが「先月」の月番号
  if (mo === 0) { mo = 12; y -= 1; }
  return `${y}-${String(mo).padStart(2,'0')}`;
}

function renderMonthBar() {
  const months = getMonths();
  document.getElementById('monthBar').innerHTML =
    '<span class="month-bar-label">期間：</span>' +
    months.map(m => `<button class="mtab${m===curMonth?' active':''}" onclick="setMonth('${m}')">${fmtMonth(m)}</button>`).join('');
}

function renderRank(data) {
  const top = data[0];
  const medals = ['🥇','🥈','🥉'];
  document.getElementById('rankList').innerHTML = data.map((d,i) => {
    const pct = Math.round((d.score/top.score)*100);
    const col = PALETTES[i%PALETTES.length];
    const pos = i < 3 ? `<span class="rank-pos">${medals[i]}</span>` : `<span class="rank-pos-num">${i+1}</span>`;
    const totalSales = (d.sales+d.mall).toLocaleString();
    const sel = chartInsts[d.name] !== undefined ? ' selected' : '';
    const btnLabel = chartInsts[d.name] !== undefined ? '▲ 閉じる' : '📊 詳しい活動内容を見る';
    const btnCls = chartInsts[d.name] !== undefined ? 'close-btn' : 'open-btn';
    const detailOpen = chartInsts[d.name] !== undefined ? ' open' : '';
    return `<div class="rank-row${sel}" id="row-${i}">
      <div class="rank-main">
        ${pos}
        <div class="rank-avatar" style="background:${col}22;color:${col}">${d.name.slice(0,2)}</div>
        <div class="rank-body">
          <div class="rank-name">${d.name}</div>
          <div class="rank-sales-total">売上合計 ¥${totalSales}</div>
        </div>
        <div class="rank-right">
          <div class="rank-score">${d.score}</div>
          <div class="rank-score-lbl">総合点</div>
        </div>
      </div>
      <div class="rank-bar-area">
        <div class="rank-bar-bg"><div class="rank-bar-fill" style="width:${pct}%;background:${col}"></div></div>
      </div>
      <div class="rank-cta">
        <button class="rank-cta-btn ${btnCls}" onclick="toggleDetail('${d.name}',${i})">${btnLabel}</button>
      </div>
      <div class="detail-panel${detailOpen}" id="detail-${i}">
        <div class="detail-hero">
          <div class="hero-row">
            <div class="hero-left">
              <div class="hero-avatar" style="background:${col}22;color:${col}">${d.name.slice(0,2)}</div>
              <div>
                <div class="hero-name">${d.name}</div>
                <div class="hero-badge" style="background:${col}18;color:${col}">${i===0?'🏆 トップメンバー':i+1+'位 / '+data.length+'名中'}</div>
              </div>
            </div>
            <div class="hero-score-block">
              <div class="hero-score">${d.score}</div>
              <div class="hero-score-lbl">総合点</div>
              <div class="hero-vs">${i===0?'👑 現在トップ！':'トップまで '+(top.score-d.score).toFixed(1)+'点差'}</div>
            </div>
          </div>
          <div class="metrics-grid">
            <div class="metric-card"><div class="metric-val">¥${d.sales.toLocaleString()}</div><div class="metric-lbl">商品売上</div></div>
            <div class="metric-card"><div class="metric-val">¥${d.mall.toLocaleString()}</div><div class="metric-lbl">モール売上</div></div>
            <div class="metric-card"><div class="metric-val">${d.story}件</div><div class="metric-lbl">ストーリー</div></div>
            <div class="metric-card"><div class="metric-val">${d.pm}人</div><div class="metric-lbl">PM獲得</div></div>
          </div>
        </div>
        <div class="dtab-row" id="dtabs-${i}">
          <button class="dtab active" onclick="switchTab(${i},'radar',this)">📡 レーダー比較</button>
          <button class="dtab" onclick="switchTab(${i},'bars',this)">📋 細かい行動内容</button>
          <button class="dtab" onclick="switchTab(${i},'advice',this)">💡 次のアクション</button>
        </div>
        <div class="panel-body">
          <div id="tab-radar-${i}"><div class="chart-wrap"><canvas id="rc-${i}"></canvas></div></div>
          <div id="tab-bars-${i}" style="display:none"><div class="action-bars" id="bars-${i}"></div></div>
          <div id="tab-advice-${i}" style="display:none"><div class="advice-list" id="advice-${i}"></div></div>
        </div>
      </div>
    </div>`;
  }).join('');

  // 開いているパネルのチャートを再描画
  data.forEach((d,i) => {
    if (chartInsts[d.name] !== undefined) {
      buildRadar(data, d, i);
      buildBars(data, d, i);
      buildAdvice(data, d, i);
    }
  });
}

function toggleDetail(name, idx) {
  const data = byMonth(curMonth);
  const member = data.find(d=>d.name===name);
  const panel = document.getElementById(`detail-${idx}`);
  const row = document.getElementById(`row-${idx}`);
  const btn = row.querySelector('.rank-cta-btn');

  if (panel.classList.contains('open')) {
    panel.classList.remove('open');
    row.classList.remove('selected');
    btn.textContent = '📊 詳しい活動内容を見る';
    btn.className = 'rank-cta-btn open-btn';
    if (chartInsts[name]) { chartInsts[name].destroy(); delete chartInsts[name]; }
  } else {
    panel.classList.add('open');
    row.classList.add('selected');
    btn.textContent = '▲ 閉じる';
    btn.className = 'rank-cta-btn close-btn';
    buildRadar(data, member, idx);
    buildBars(data, member, idx);
    buildAdvice(data, member, idx);
    setTimeout(() => panel.scrollIntoView({behavior:'smooth', block:'nearest'}), 100);
  }
}

function buildRadar(data, member, idx) {
  const top = data[0];
  const rank = data.findIndex(d=>d.name===member.name);
  const col = PALETTES[rank%PALETTES.length];
  if (chartInsts[member.name]) { chartInsts[member.name].destroy(); }
  const labels = AXES.map(a=>a.label);
  const myVals  = AXES.map(a=>Math.round((Math.min(member[a.k],a.max)/a.max)*100));
  const topVals = AXES.map(a=>Math.round((Math.min(top[a.k],a.max)/a.max)*100));
  chartInsts[member.name] = new Chart(document.getElementById(`rc-${idx}`), {
    type:'radar',
    data:{labels,datasets:[
      {label:top.name+'（1位）',data:topVals,backgroundColor:'rgba(24,95,165,.08)',borderColor:'#185FA5',borderWidth:1.5,pointRadius:3,pointBackgroundColor:'#185FA5'},
      {label:member.name,data:myVals,backgroundColor:col+'28',borderColor:col,borderWidth:2,pointRadius:4,pointBackgroundColor:col},
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:true,position:'bottom',labels:{font:{size:11},color:'#888',boxWidth:10,padding:14}}},
      scales:{r:{min:0,max:100,ticks:{display:false},grid:{color:'rgba(0,0,0,.07)'},angleLines:{color:'rgba(0,0,0,.07)'},pointLabels:{font:{size:11},color:'#555'}}}
    }
  });
}

function buildBars(data, member, idx) {
  const top = data[0];
  const rank = data.findIndex(d=>d.name===member.name);
  const col = PALETTES[rank%PALETTES.length];
  const myVals  = AXES.map(a=>Math.round((Math.min(member[a.k],a.max)/a.max)*100));
  const topVals = AXES.map(a=>Math.round((Math.min(top[a.k],a.max)/a.max)*100));
  document.getElementById(`bars-${idx}`).innerHTML = AXES.map((a,i)=>{
    const myPct=myVals[i], topPct=topVals[i], gap=topPct-myPct;
    const barCol = gap>35?'#E24B4A':gap>15?'#BA7517':'#1D9E75';
    const pillBg = gap>35?'#fff0f0':gap>15?'#fff8e1':'#f0faf6';
    const gapLabel = gap>35?'要強化':gap>15?'伸び代あり':'良好';
    return `<div class="ab-row">
      <div class="ab-label">${a.label}</div>
      <div class="ab-right">
        <div class="ab-track">
          <div class="ab-bar-top" style="width:${topPct}%;background:#185FA5"></div>
          <div class="ab-bar-you" style="width:${myPct}%;background:${barCol}">
            ${myPct>15?`<span class="ab-bar-label">${myPct}%</span>`:''}
          </div>
        </div>
        <div class="ab-meta">
          <span class="ab-myval">${a.fmt(member[a.k])}</span>
          <span class="ab-topval">トップ: ${a.fmt(top[a.k])}</span>
          <span class="ab-gap-pill" style="background:${pillBg};color:${barCol}">${gapLabel}</span>
        </div>
      </div>
    </div>`;
  }).join('');
}

function buildAdvice(data, member, idx) {
  const top = data[0];
  const myVals  = AXES.map(a=>Math.round((Math.min(member[a.k],a.max)/a.max)*100));
  const topVals = AXES.map(a=>Math.round((Math.min(top[a.k],a.max)/a.max)*100));
  const sorted = AXES.map((a,i)=>({a,gap:topVals[i]-myVals[i]})).sort((a,b)=>b.gap-a.gap);
  document.getElementById(`advice-${idx}`).innerHTML = sorted.slice(0,4).map(({a,gap})=>{
    const level = gap>35?'weak':gap>15?'mid':'good';
    const tag   = gap>35?'⚡ 要強化':gap>15?'📈 伸び代あり':'✅ 良好';
    return `<div class="advice-card ${level}">
      <div class="advice-tag">${tag}</div>
      <div class="advice-action-name">${a.label}</div>
      <div class="advice-text">${TIPS[a.k][level]}</div>
      <div class="advice-numbers">
        <span>📌 現在: ${a.fmt(member[a.k])}</span>
        <span>🏆 トップ: ${a.fmt(top[a.k])}</span>
      </div>
    </div>`;
  }).join('');
}

function switchTab(idx, id, btn) {
  ['radar','bars','advice'].forEach(t => {
    document.getElementById(`tab-${t}-${idx}`).style.display = t===id?'block':'none';
  });
  document.querySelectorAll(`#dtabs-${idx} .dtab`).forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function setMonth(m) {
  curMonth = m;
  chartInsts = {};
  renderMonthBar();
  renderRank(byMonth(m));
}

async function init() {
  try {
    await fetchData();
    const months = getMonths();
    const lastMonth = getLastMonth();
    // 先月のデータがあればそれをデフォルト、なければ最新月
    curMonth = months.includes(lastMonth) ? lastMonth : months[0];
    document.getElementById('loadingState').style.display = 'none';
    document.getElementById('mainContent').style.display = 'block';
    renderMonthBar();
    renderRank(byMonth(curMonth));
  } catch(e) {
    document.getElementById('loadingState').style.display = 'none';
    const err = document.getElementById('errorState');
    err.style.display = 'block';
    err.textContent = 'エラー: ' + e.message;
  }
}

init();
</script>
</body>
</html>
